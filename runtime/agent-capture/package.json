{
  "name": "@nimiplatform/mod-agent-capture",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nimi-mod build",
    "dev": "nimi-mod dev",
    "doctor": "nimi-mod doctor",
    "pack": "nimi-mod pack",
    "watch": "nimi-mod dev",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test:services": "tsx --test test/*.test.ts",
