{
  "name": "@nimiplatform/mod-mint-you",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ../scripts/build-mod.mjs --mod mint-you",
    "watch": "node ../scripts/build-mod.mjs --mod mint-you --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "npx tsx --test test/*.test.ts",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run build",
    "clean": "rm -rf dist"
  }
}
