{
  "name": "@nimiplatform/mod-textplay",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nimi-mod build",
    "dev": "nimi-mod dev",
    "doctor": "nimi-mod doctor",
    "pack": "nimi-mod pack",
    "watch": "nimi-mod dev",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "npx tsx --test test/*.mjs",
    "test:smoke": "npx tsx --tsconfig scripts/tsconfig.smoke.json scripts/smoke-start-click.mjs && npx tsx --tsconfig scripts/tsconfig.smoke.json scripts/smoke-start-replay-conflict.mjs",
    "test:regression:long": "npx tsx --tsconfig scripts/tsconfig.smoke.json scripts/regression-long-run.mjs",
    "verify:spec": "pnpm -C .. run check:spec:textplay",
    "verify:code": "pnpm run typecheck && pnpm run test && pnpm run test:regression:long && pnpm run build",
    "verify": "pnpm run verify:spec && pnpm run verify:code",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nimiplatform/sdk": "file:../../sdk",
    "react": "19.2.3"
  },
  "devDependencies": {
    "@nimiplatform/dev-tools": "file:../../dev-tools",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
