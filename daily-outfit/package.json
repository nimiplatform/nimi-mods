{
  "name": "@nimiplatform/mod-daily-outfit",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ../scripts/build-mod.mjs --mod daily-outfit",
    "watch": "node ../scripts/build-mod.mjs --mod daily-outfit --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
