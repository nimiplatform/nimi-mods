{
  "name": "@nimiplatform/mod-buddy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nimi-mod build",
    "dev": "nimi-mod dev",
    "doctor": "nimi-mod doctor",
    "pack": "nimi-mod pack",
    "watch": "nimi-mod dev",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "npx tsx --test test/*.test.ts",
    "model:validate": "node ./scripts/model-admin.mjs validate",
    "model:add": "node ./scripts/model-admin.mjs add",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nimiplatform/sdk": "file:../../sdk",
    "pixi.js": "^6.5.10",
    "pixi-live2d-display": "^0.4.0",
    "react": "19.2.3"
  },
  "devDependencies": {
    "@nimiplatform/dev-tools": "file:../../dev-tools",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  }
}
