{
  "name": "@nimiplatform/mod-buddy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ../scripts/build-mod.mjs --mod buddy",
    "watch": "node ../scripts/build-mod.mjs --mod buddy --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "npx tsx --test test/*.test.ts",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pixi.js": "^6.5.10",
    "pixi-live2d-display": "^0.4.0"
  }
}
